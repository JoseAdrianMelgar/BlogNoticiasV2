@using Microsoft.AspNet.Identity
@if (Request.IsAuthenticated)
{
    using (Html.BeginForm("LogOff", "Account", FormMethod.Post, new { id = "logoutForm", @class = "d-flex" }))
    {
        @Html.AntiForgeryToken()
        <ul class="navbar-nav mb-2 mb-lg-0">
            <li class="nav-item">
                <span class="navbar-text text-white me-3">Hola, @User.Identity.GetUserName()!</span>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="@Url.Action("Index", "Manage")">Cuenta</a>
            </li>
            <li class="nav-item">
                <button type="submit" class="btn btn-link nav-link" style="padding-left:0;">Cerrar sesión</button>
            </li>
        </ul>
    }
}
else
{
    <ul class="navbar-nav mb-2 mb-lg-0">
        <li class="nav-item"><a class="nav-link" href="@Url.Action("Login", "Account")">Iniciar sesión</a></li>
        <li class="nav-item"><a class="nav-link" href="@Url.Action("Register", "Account")">Registrarse</a></li>
    </ul>
}
