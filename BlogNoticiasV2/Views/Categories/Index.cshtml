@model IEnumerable<BlogNoticiasV2.Models.Category>
@{
    ViewBag.Title = "Categorías";
}
<h2>@ViewBag.Title</h2>

<p>
    <a class="btn btn-primary" href="@Url.Action("Create")">Crear nueva categoría</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.FirstOrDefault().Nombre)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Nombre)</td>
                <td>
                    <a class="btn btn-sm btn-outline-secondary" href="@Url.Action("Details", new { id = item.Id })">Detalles</a>
                    <a class="btn btn-sm btn-outline-primary" href="@Url.Action("Edit", new { id = item.Id })">Editar</a>
                    <a class="btn btn-sm btn-outline-danger" href="@Url.Action("Delete", new { id = item.Id })">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <div class="alert alert-info">No hay categorías creadas.</div>
}
